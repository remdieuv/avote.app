# PostgreSQL — ex. postgresql://USER:PASSWORD@localhost:5432/avote
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/avote"

# JWT cookies (auth admin). Minimum 16 caractères.
JWT_SECRET="change-me-at-least-16-chars"

# Front Next (CORS + cookies). Ex. http://localhost:3000
# CLIENT_URL=http://localhost:3000

# Origine publique de cette API (sans slash final). Obligatoire en prod pour les URLs
# logo / fond (/uploads/...) renvoyées au client. Doit matcher l’URL utilisée dans NEXT_PUBLIC_API_URL.
# PUBLIC_API_ORIGIN="https://votre-api.example.com"

# Cloudinary (uploads persistants)
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# Mot de passe optionnel pour l’utilisateur legacy après migrate (seed).
# DEV_LEGACY_PASSWORD=devpassword
